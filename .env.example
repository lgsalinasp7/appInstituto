# ===========================================
# Variables de Entorno - KaledSoft Platform
# ===========================================
# Copiar como .env y rellenar valores reales. Este archivo es seguro para compartir con IA o en el repo.
#
# Prisma: si usas prisma.config.ts, asegúrate de cargar dotenv según
# https://pris.ly/prisma-config-env-vars
#
# Neon: ver docs/NEON_UNA_SOLA_RAMA.md para evitar ramas preview innecesarias.

# ---- Base de datos (Neon PostgreSQL) ----
# DATABASE_URL: host con -pooler (runtime / Prisma con pool)
# DIRECT_URL: mismo usuario/DB, host sin -pooler (migraciones; evita P1002 advisory lock)
#BD PRODUCTION (ejemplo de comentario en .env local)
#DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
#DIRECT_URL="postgresql://neondb_owner:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://user:password@ep-example.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ---- Seeds (protección) ----
# NO usar SEED_ALLOW_WIPE en producción. Solo local para db seed / migrate reset.
# SEED_ALLOW_WIPE=1

# ---- Aplicación ----
NODE_ENV="development"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_ROOT_DOMAIN="kaledsoft.tech"

# ---- Seguridad / cron ----
CRON_SECRET="genera-un-secreto-largo-aleatorio"

# ---- Email (Resend) ----
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@tu-dominio.com"
RESEND_FROM_NAME="KaledSoft"

# ---- Resend Webhook ----
RESEND_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ---- Next / Vercel Flags ----
FLAGS_SECRET="genera-un-secreto-para-flags"

# ---- IA (agentes / gateway) ----
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
AI_GATEWAY_API_KEY="vck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
GOOGLE_GENERATIVE_AI_API_KEY="AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
NEXT_PUBLIC_AI_ENABLED="true"

# ---- WhatsApp Business API ----
WHATSAPP_API_URL="https://graph.facebook.com/v22.0"
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER=""
# Webhook verify / app secret (Meta Developer Console)
#WHATSAPP_VERIFY_TOKEN=""
#WHATSAPP_APP_SECRET=""
# Fallback para webhooks cuando no hay mapeo por phone_number_id
DEFAULT_TENANT_ID=""

# ---- Meta Pixel (Facebook Ads) ----
META_PIXEL_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""

# ---- Google Analytics (Measurement ID: formato G-XXXXXXXXXX) ----
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# ---- Telegram ----
TELEGRAM_BOT_TOKEN="123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ---- Vercel Blob ----
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ---- Sentry (errores 5xx + observabilidad) ----
# Obtener DSN en https://sentry.io tras crear el proyecto Next.js.
# El wrapper withSentryConfig solo se activa si SENTRY_DSN esta presente.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# Para upload de source maps en CI (iteracion futura). Dejar vacio si no se usa.
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# ---- GitHub Actions (Settings → Secrets → Actions) ----
# Migraciones develop: DIRECT_DATABASE_URL_DEV o DATABASE_URL_DEV
# Migraciones main: DIRECT_DATABASE_URL_PROD o DATABASE_URL_PROD
# Deploy hooks: VERCEL_DEPLOY_HOOK_DEV, VERCEL_DEPLOY_HOOK_PROD
# CI dev HTTP 404 en hook: docs/VERCEL_DEPLOY_HOOK_DEV.md
