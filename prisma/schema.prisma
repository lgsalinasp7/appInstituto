  label          String
  amountCop      Decimal              @db.Decimal(12, 2)
  allocationDate DateTime
  monthIndex     Int?
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cohort       AcademyCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  campaignCost CampaignCost? @relation(fields: [campaignCostId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([cohortId])
  @@index([campaignCostId])
  @@index([category])
  @@index([allocationDate])
}

// ============================================
// MODELO: Leads de Plataforma KaledSoft (Directos)
// ============================================
model KaledLead {
  id              String   @id @default(cuid())
  name            String
  email           String
  phone           String?
  city            String?
  status          String   @default("NUEVO") // NUEVO, CONTACTADO, DEMO, CONVERTIDO, PERDIDO
  source          String   @default("MASTERCLASS")

  // Tenant isolation
  tenantId        String?
  tenant          Tenant?  @relation(fields: [tenantId], references: [id])

  // Datos específicos de la masterclass o interés
  observations    String?  @db.Text
  filteringData   Json?    // Respuestas a preguntas de filtro

  // UTM Tracking
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmContent      String?

  // CRM - Gestión de campañas
  campaignId      String?

  // Email Engagement Tracking
  emailOpens         Int       @default(0)
  emailClicks        Int       @default(0)
  lastEmailOpenedAt  DateTime?
  lastEmailClickedAt DateTime?
  lastEmailSentAt    DateTime?
  lastEmailTemplateId String?

  // Lead Scoring (0-100)
  leadScore          Int      @default(0)
  interestLevel      String   @default("low") // low, medium, high

  // Masterclass Tracking
  masterclassRegisteredAt DateTime?
  masterclassAttendedAt   DateTime?
  purchasedAt             DateTime?

  // Soft delete
  deletedAt       DateTime?
  deletedBy       String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relaciones CRM
  campaign        KaledCampaign?            @relation(fields: [campaignId], references: [id])
  interactions    KaledLeadInteraction[]
  emailLogs       KaledEmailLog[]

  @@unique([email, tenantId])
  @@index([status])
  @@index([email])
  @@index([campaignId])
  @@index([deletedAt])
  @@index([leadScore])
  @@index([interestLevel])
  @@index([tenantId])
}

// ============================================
// CRM: Interacciones con KaledLeads
// ============================================
model KaledLeadInteraction {
  id          String                    @id @default(cuid())
  type        KaledInteractionType
  content     String                    @db.Text
  metadata    Json?                     // { duration: 30, result: "Interesado" }
  kaledLeadId String
  userId      String?                   // Quién lo registró (null si automático)
  tenantId    String?
  createdAt   DateTime                  @default(now())

  kaledLead   KaledLead                 @relation(fields: [kaledLeadId], references: [id], onDelete: Cascade)
  user        User?                     @relation(fields: [userId], references: [id])
  tenant      Tenant?                   @relation(fields: [tenantId], references: [id])

  @@index([kaledLeadId])
  @@index([type])
  @@index([createdAt])
  @@index([tenantId])
}

enum KaledInteractionType {
  NOTA
  CORREO
  WHATSAPP
  LLAMADA
  REUNION
  CAMBIO_ESTADO
  TAREA
}

// ============================================
// CRM: Campañas de KaledLeads
// ============================================
model KaledCampaign {
  id          String                    @id @default(cuid())
  name        String
  description String?                   @db.Text
  status      KaledCampaignStatus       @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  timeline    Json?                     // Configuración flexible de fases

  // Tenant isolation
  tenantId    String?
  tenant      Tenant?                   @relation(fields: [tenantId], references: [id])

  // Enlaces de la campaña
  eventUrl          String?  // Zoom/Google Meet URL
  checkoutUrl       String?  // URL de pago/checkout
  calendlyUrl       String?  // URL para agendar llamadas
  recordingUrl      String?  // URL de grabación (para no-show)

  // Metadata del evento
  eventDate         DateTime?
  eventTime         String?  // "7:00 PM COT"
  eventDuration     Int?     // minutos

  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  leads       KaledLead[]
  templates   KaledEmailTemplate[]
  sequences   KaledEmailSequence[]

  @@unique([name, tenantId])
  @@index([status])
  @@index([tenantId])
}

enum KaledCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

// ============================================
// CRM: Plantillas de Email para KaledLeads
// ============================================
model KaledEmailTemplate {
  id          String                    @id @default(cuid())
  name        String
  subject     String
  htmlContent String                    @db.Text
  variables   String[]                  // ["nombre", "email", "enlace"]
  category    String                    @default("GENERAL") // AUTOMATIC, SEMI_AUTOMATIC, MANUAL
  isActive    Boolean                   @default(true)
  isLibraryTemplate Boolean             @default(false) // Plantillas pre-diseñadas de la librería
  phase       String?                   // FASE_1, FASE_2, FASE_3, NO_SHOW
  campaignId  String?
  tenantId    String?
  createdAt   DateTime                  @default(now())

  campaign    KaledCampaign?            @relation(fields: [campaignId], references: [id])
  tenant      Tenant?                   @relation(fields: [tenantId], references: [id])
  emailLogs   KaledEmailLog[]
  sequenceSteps KaledEmailSequenceStep[]

  @@unique([name, tenantId])
  @@index([category])
  @@index([campaignId])
  @@index([isLibraryTemplate])
  @@index([phase])
  @@index([tenantId])
}

// ============================================
// CRM: Secuencias Automáticas de Email
// ============================================
model KaledEmailSequence {
  id            String                    @id @default(cuid())
  name          String
  triggerType   KaledTriggerType          // TIME_BASED, ACTION_BASED, STAGE_BASED
  triggerConfig Json                      // { status: "NUEVO", delayHours: 0 }
  isActive      Boolean                   @default(true)
  campaignId    String?
  tenantId      String?
  createdAt     DateTime                  @default(now())

  campaign      KaledCampaign?            @relation(fields: [campaignId], references: [id])
  tenant        Tenant?                   @relation(fields: [tenantId], references: [id])
  steps         KaledEmailSequenceStep[]

  @@unique([name, tenantId])
  @@index([triggerType])
  @@index([isActive])
  @@index([tenantId])
}

enum KaledTriggerType {
  TIME_BASED      // Después de X horas/días
  ACTION_BASED    // Al registrarse, agendar demo, etc.
  STAGE_BASED     // Al cambiar de estado
}

model KaledEmailSequenceStep {
  id          String                    @id @default(cuid())
  sequenceId  String
  templateId  String
  orderIndex  Int                       // 0, 1, 2...
  delayHours  Int
  conditions  Json?
  tenantId    String?

  sequence    KaledEmailSequence        @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  template    KaledEmailTemplate        @relation(fields: [templateId], references: [id])
  tenant      Tenant?                   @relation(fields: [tenantId], references: [id])

  @@index([sequenceId])
  @@index([tenantId])
}

// ============================================
// CRM: Log de Emails Enviados a KaledLeads
// ============================================
model KaledEmailLog {
  id              String                    @id @default(cuid())
  to              String
  subject         String
  templateId      String?
  kaledLeadId     String?
  tenantId        String?
  status          String                    @default("PENDING") // PENDING, SENT, FAILED, DELIVERED, OPENED, CLICKED, BOUNCED
  resendId        String?
  requiresApproval Boolean                  @default(false)
  approvedBy      String?
  approvedAt      DateTime?
  metadata        Json?
  sentAt          DateTime                  @default(now())

  // Email Tracking
  deliveredAt     DateTime?
  openedAt        DateTime?
  clickedAt       DateTime?
  bouncedAt       DateTime?
  openCount       Int                       @default(0)
  clickCount      Int                       @default(0)

  template        KaledEmailTemplate?       @relation(fields: [templateId], references: [id])
  kaledLead       KaledLead?                @relation(fields: [kaledLeadId], references: [id])
  tenant          Tenant?                   @relation(fields: [tenantId], references: [id])

  @@index([kaledLeadId])
  @@index([status])
  @@index([requiresApproval])
  @@index([resendId])
  @@index([tenantId])
}

// ============================================
// ACADEMIA LMS (Kaled Academy)
// ============================================
model AcademyCourse {
  id            String   @id @default(cuid())
  title         String
  description   String   @db.Text
  category      String
  duration      String
  level         String
  price         Float
  durationWeeks Int?     @default(24)
  description2  String?  @db.Text
  isActive      Boolean  @default(true)
  tenantId      String
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy     User               @relation("AcademyCourseCreator", fields: [createdById], references: [id])
  modules       AcademyModule[]
  enrollments   AcademyEnrollment[]
  cohorts       AcademyCohort[]
  announcements AcademyAnnouncement[]

  @@index([tenantId])
  @@index([isActive])
}

model AcademyModule {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  order       Int
  isActive    Boolean  @default(true)
  courseId    String
  createdAt   DateTime @default(now())

  course        AcademyCourse      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons       AcademyLesson[]
  kaledSessions AcademyKaledSession[]

  @@index([courseId])
  @@index([order])
}

model AcademyLesson {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  content     String   @db.Text
  videoUrl    String?
  duration    Int      // minutos
  order       Int
  isActive    Boolean  @default(true)
  moduleId    String
  createdAt   DateTime @default(now())

  module         AcademyModule          @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress       AcademyStudentProgress[]
  meta           AcademyLessonMeta?
  cralChallenges AcademyCRALChallenge[]
  quizzes        AcademyQuiz[]
  deliverables   AcademyDeliverable[]
  kaledSessions  AcademyKaledSession[]

  @@index([moduleId])
  @@index([order])
}

model AcademyEnrollment {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  cohortId   String?
  status     String   @default("ACTIVE")
  progress   Decimal  @default(0) @db.Decimal(5, 2)
  listPriceCop      Decimal  @default(0) @db.Decimal(12, 2)
  discountAmountCop Decimal  @default(0) @db.Decimal(12, 2)
  netRevenueCop     Decimal  @default(0) @db.Decimal(12, 2)
  paidAmountCop     Decimal  @default(0) @db.Decimal(12, 2)
  refundedAmountCop Decimal  @default(0) @db.Decimal(12, 2)
  paymentStatus     FinancePaymentStatus @default(PENDING)
  enrolledAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isTrial             Boolean   @default(false)
  trialExpiresAt      DateTime?
  trialAllowedLessonId String?

  user     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course   AcademyCourse          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  cohort   AcademyCohort?          @relation(fields: [cohortId], references: [id], onDelete: SetNull)
  snapshot AcademyStudentSnapshot?

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([cohortId])
  @@index([status])
  @@index([paymentStatus])
}

model AcademyCohort {
  id              String                   @id @default(cuid())
  name            String
  startDate       DateTime
  endDate         DateTime
  maxStudents     Int
  currentStudents Int                      @default(0)
  status          AcademyCohortStatus
  schedule        Json
  courseId        String
  tenantId        String
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  course           AcademyCourse           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tenant           Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enrollments      AcademyEnrollment[]
  events           AcademyCohortEvent[]
  assessments      AcademyAssessment[]
  kaledSessions    AcademyKaledSession[]
  studentSnapshots AcademyStudentSnapshot[]
  saasProjects     AcademySaasProject[]
  demoDayResults   AcademyDemoDayResult[]
  announcements    AcademyAnnouncement[]
  costAllocations  AcademyCohortCostAllocation[]

  @@index([courseId])
  @@index([tenantId])
  @@index([status])
}

model AcademyCohortEvent {
  id          String       @id @default(cuid())
  cohortId    String
  title       String
  type        String       // HANDS_ON, LECTURE, LIVE, etc.
  dayOfWeek   Int?         // 0-6 (domingo-sábado)
  startTime   String?      // "09:00"
  endTime     String?
  scheduledAt DateTime?    // para eventos puntuales
  createdAt   DateTime     @default(now())

  cohort AcademyCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)

  @@index([cohortId])
}

model AcademyAssessment {
  id               String   @id @default(cuid())
  cohortId         String
  title            String
  type             String   // CHECKPOINT, EXAM, QUIZ
  scheduledAt      DateTime
  durationMinutes  Int?
  createdAt        DateTime @default(now())

  cohort AcademyCohort            @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  results AcademyAssessmentResult[]

  @@index([cohortId])
}

model AcademyAssessmentResult {
  id           String   @id @default(cuid())
  userId       String
  assessmentId String
  score        Decimal? @db.Decimal(5, 2)
  completed    Boolean  @default(false)
  completedAt  DateTime?
  createdAt    DateTime @default(now())

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessment AcademyAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([userId, assessmentId])
  @@index([userId])
  @@index([assessmentId])
}

model AcademyStudentProgress {
  id             String    @id @default(cuid())
  userId         String
  lessonId       String
  completed      Boolean   @default(false)
  completedAt    DateTime?
  videoWatchedAt DateTime?
  videoProgress  Int?      // % del video visto (0-100)
  timeSpentSec   Int?      // tiempo total en la lección (segundos)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson AcademyLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
