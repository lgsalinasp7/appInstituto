  @@index([tenantId])
  @@index([createdAt])
}

model AiMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String   @db.Text
  toolCalls      Json?
  toolResults    Json?
  createdAt      DateTime @default(now())

