  kaledIntro  String?     @db.Text
  concepts    Json?
  tenantId    String

  lesson AcademyLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  tenant Tenant        @relation(fields: [tenantId], references: [id])

  @@index([lessonId])
  @@index([weekNumber])
  @@index([tenantId])
}

model AcademyCRALChallenge {
