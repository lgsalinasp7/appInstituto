enum SoftwareSaleStatus {
  PENDING
  CLOSED_WON
  CANCELLED
}

enum RevenueRecognitionMode {
  CASH_IN
  PRORATED
}

enum CohortCostCategory {
  ADS
  INSTRUCTOR
  PLATFORM
  TOOLS
  OTHER
}

enum CohortCostSourceType {
  MANUAL
  CAMPAIGN
}

model SoftwareSale {
  id                 String             @id @default(cuid())
  tenantId           String
  customerTenantId   String?
  customerName       String
  productName        String
  planName           String?
  saleDate           DateTime
  contractStartDate  DateTime
  contractEndDate    DateTime
  amountCop          Decimal            @db.Decimal(12, 2)
  collectedAmountCop Decimal            @default(0) @db.Decimal(12, 2)
  status             SoftwareSaleStatus @default(PENDING)
  paymentStatus      FinancePaymentStatus @default(PENDING)
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
