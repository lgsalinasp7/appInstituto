  revenueSchedules SoftwareRevenueSchedule[]

  @@index([tenantId])
  @@index([customerTenantId])
  @@index([saleDate])
  @@index([status])
  @@index([paymentStatus])
}

model SoftwareRevenueSchedule {
  id                  String                @id @default(cuid())
  softwareSaleId      String
  tenantId            String
  mode                RevenueRecognitionMode @default(PRORATED)
