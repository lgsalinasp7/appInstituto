// ============================================================
// KALEDACADEMY — Schema de Prisma (Extensión de KaledSoft)
// Tenant slug: "kaledacademy" dentro del modelo Tenant
//
// REGLA FUNDAMENTAL: Todo modelo lleva tenantId → Tenant
// para respetar el aislamiento multi-tenant de KaledSoft.
//
// MODELOS EXISTENTES QUE YA USA KALEDACADEMY (NO duplicar):
//   - Tenant              → el tenant "kaledacademy"
//   - User                → estudiantes, instructores, admins
//   - Role                → ACADEMY_STUDENT | ACADEMY_TEACHER | ACADEMY_ADMIN
//   - AcademyCourse       → cursos/programas del bootcamp
//   - AcademyModule       → módulos del curso (Módulo 1..4)
//   - AcademyLesson       → sesiones (S1..S48)
//   - AcademyLessonTask   → tareas CRAL por sesión
//   - AcademyTaskCompletion
//   - AcademyEnrollment   → matrícula estudiante ↔ curso
//   - AcademyStudentProgress → progreso por lección
//   - AcademyCohort       → cohorte (grupo de estudiantes)
//   - AcademyCohortEvent  → eventos del calendario
//   - AcademyAssessment   → evaluaciones
//   - AcademyAssessmentResult
//   - AiConversation + AiMessage → chat con Kaled AI
//   - AiUsage             → control de tokens/costo por tenant
//   - AgentMemory         → memoria del agente Kaled
//   - Invitation          → invitar estudiantes con academyRole
// ============================================================

// ============================================================
// SECCIÓN 1: CONTENIDO DEL BOOTCAMP (LO QUE FALTA)
// ============================================================

// Tipo de sesión dentro del temario
// Los AcademyLesson ya existen pero les falta metadata
// específica del bootcamp KaledSoft
model AcademyLessonMeta {
  id          String  @id @default(cuid())
  lessonId    String  @unique
  sessionType SessionType @default(TEORIA)
  weekNumber  Int                     // 1..16
  dayOfWeek   DayOfWeek               // LUNES | MIERCOLES | VIERNES
  phaseTarget CRALPhase?              // CONSTRUIR | ROMPER | AUDITAR | LANZAR
  videoUrl    String?                 // YouTube embed recomendado por Kaled
  videoTitle  String?
  analogyText String? @db.Text       // La analogía de Kaled para esta sesión
  kaledIntro  String? @db.Text       // Mensaje inicial de Kaled para esta sesión
  concepts    Json?                  // Array de {key, title, body} para los pills clickeables
  tenantId    String

  lesson  AcademyLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  tenant  Tenant        @relation(fields: [tenantId], references: [id])

  @@index([lessonId])
  @@index([weekNumber])
  @@index([tenantId])
}

// Reto CRAL (Construir·Romper·Auditar·Lanzar) por sesión
// Complementa AcademyLessonTask que solo tiene title/type/order
model AcademyCRALChallenge {
  id          String    @id @default(cuid())
  lessonId    String
  phase       CRALPhase
  title       String
  description String    @db.Text
  taskCode    String?   @db.Text // Snippet de código para el reto
  order       Int       @default(0)
  tenantId    String

  lesson  AcademyLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  tenant  Tenant        @relation(fields: [tenantId], references: [id])
  completions AcademyCRALCompletion[]

  @@index([lessonId])
  @@index([phase])
  @@index([tenantId])
}

// Registro de completado del reto CRAL por estudiante
model AcademyCRALCompletion {
  id          String    @id @default(cuid())
  userId      String
  challengeId String
  phase       CRALPhase
  completed   Boolean   @default(false)
  completedAt DateTime?
  githubUrl   String?   // Link al repositorio del entregable
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge AcademyCRALChallenge  @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([userId])
  @@index([challengeId])
  @@index([phase])
}

// Quiz por sesión (verificación de comprensión)
model AcademyQuiz {
  id       String @id @default(cuid())
  lessonId String
  question String @db.Text
  tenantId String
  order    Int    @default(0)

  lesson  AcademyLesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  tenant  Tenant         @relation(fields: [tenantId], references: [id])
  options AcademyQuizOption[]
  results AcademyQuizResult[]

  @@index([lessonId])
  @@index([tenantId])
}

model AcademyQuizOption {
  id        String  @id @default(cuid())
  quizId    String
  label     String                   // "A", "B", "C", "D"
  text      String  @db.Text
  isCorrect Boolean @default(false)
  feedback  String? @db.Text         // Mensaje de Kaled para esta opción

  quiz AcademyQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model AcademyQuizResult {
  id              String   @id @default(cuid())
  userId          String
  quizId          String
  selectedOptionId String?
  isCorrect       Boolean  @default(false)
  answeredAt      DateTime @default(now())

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz AcademyQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([userId, quizId])
  @@index([userId])
  @@index([quizId])
}

// Entregable semanal (checklist + GitHub URL)
model AcademyDeliverable {
  id          String  @id @default(cuid())
  lessonId    String                        // Sesión del viernes (lanzamiento)
  weekNumber  Int
  title       String
  description String  @db.Text
  isFinal     Boolean @default(false)      // true = entregable integrador de módulo
  tenantId    String

  lesson      AcademyLesson             @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  tenant      Tenant                    @relation(fields: [tenantId], references: [id])
  checkItems  AcademyDeliverableItem[]
  submissions AcademyDeliverableSubmission[]

  @@index([lessonId])
  @@index([weekNumber])
  @@index([tenantId])
}

model AcademyDeliverableItem {
  id             String @id @default(cuid())
  deliverableId  String
  text           String
  order          Int    @default(0)

  deliverable AcademyDeliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)

  @@index([deliverableId])
}

// Entrega del estudiante del entregable semanal
model AcademyDeliverableSubmission {
  id             String                   @id @default(cuid())
  userId         String
  deliverableId  String
  githubUrl      String?
  deployUrl      String?
  status         DeliverableStatus        @default(PENDIENTE)
  score          Decimal?                 @db.Decimal(5, 2)
  feedback       String?                  @db.Text
  checkedItems   String[]                 // IDs de AcademyDeliverableItem marcados
  submittedAt    DateTime?
  reviewedAt     DateTime?
  reviewedById   String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliverable  AcademyDeliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  reviewedBy   User?              @relation("DeliverableReviewer", fields: [reviewedById], references: [id])

  @@unique([userId, deliverableId])
  @@index([userId])
  @@index([deliverableId])
  @@index([status])
  @@index([reviewedById])
}

// ============================================================
// SECCIÓN 2: AGENTE KALED AI (TUTOR DE LA ACADEMIA)
// ============================================================

// Conversación del estudiante con Kaled (tutor IA)
// Extiende AiConversation con contexto de academia
model AcademyKaledSession {
  id             String   @id @default(cuid())
  conversationId String   @unique   // → AiConversation.id
  userId         String
  lessonId       String?            // Contexto: sesión en curso
  moduleId       String?            // Contexto: módulo en curso
  cohortId       String?
  sessionType    KaledSessionType   @default(LESSON_SUPPORT)
  tenantId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson       AcademyLesson? @relation(fields: [lessonId], references: [id])
  module       AcademyModule? @relation(fields: [moduleId], references: [id])
  cohort       AcademyCohort? @relation(fields: [cohortId], references: [id])
  tenant       Tenant         @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([lessonId])
  @@index([tenantId])
}

// Progreso agregado del estudiante (snapshot para dashboard)
// Se recalcula periódicamente o en cada acción relevante
model AcademyStudentSnapshot {
  id                  String   @id @default(cuid())
  userId              String
  cohortId            String
  enrollmentId        String   @unique
  overallProgress     Decimal  @default(0) @db.Decimal(5, 2)  // 0..100
  lessonsCompleted    Int      @default(0)
  lessonsTotal        Int      @default(0)
  quizzesPassed       Int      @default(0)
  quizzesTotal        Int      @default(0)
  deliverablesSubmitted Int    @default(0)
  deliverablesApproved  Int    @default(0)
  cralCompleted       Json?    // { CONSTRUIR: 5, ROMPER: 3, AUDITAR: 2, LANZAR: 4 }
  currentStreak       Int      @default(0)  // días consecutivos activos
  totalTimeSpentSec   Int      @default(0)
  lastActivityAt      DateTime?
  kaledInteractions   Int      @default(0)  // veces que usó al tutor IA
  snapshotAt          DateTime @default(now())
  tenantId            String

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  cohort     AcademyCohort @relation(fields: [cohortId], references: [id])
  tenant     Tenant        @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([cohortId])
  @@index([tenantId])
  @@index([overallProgress])
}

// ============================================================
// SECCIÓN 3: DEMO DAY Y PROYECTO SAAS DEL ESTUDIANTE
// ============================================================

// Proyecto SaaS que construye el estudiante durante el bootcamp
model AcademySaasProject {
  id           String        @id @default(cuid())
  userId       String
  cohortId     String
  name         String                              // Nombre del SaaS
  description  String?       @db.Text
  githubUrl    String?
  deployUrl    String?                             // URL en producción (Vercel)
  domainUrl    String?                             // Dominio propio
  techStack    Json?                               // { frontend, backend, db, auth, ai, payments }
  planFree     String?       @db.Text             // Descripción del plan gratuito
  planPro      String?       @db.Text             // Descripción del plan Pro
  realUsers    Int           @default(0)           // Usuarios reales conseguidos
  status       SaasProjectStatus @default(EN_CONSTRUCCION)
  lightScorePerformance   Decimal? @db.Decimal(5, 2) // Lighthouse score
  lightScoreAccessibility Decimal? @db.Decimal(5, 2)
  tenantId     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  cohort       AcademyCohort @relation(fields: [cohortId], references: [id])
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  weeklyUpdates AcademySaasUpdate[]
  demoDayResult AcademyDemoDayResult?

  @@unique([userId, cohortId])
  @@index([userId])
  @@index([cohortId])
  @@index([status])
  @@index([tenantId])
}

// Actualizaciones semanales del proyecto (una por semana)
model AcademySaasUpdate {
  id          String   @id @default(cuid())
  projectId   String
  weekNumber  Int
  githubUrl   String?
  deployUrl   String?
  summary     String   @db.Text
  cralDone    Json?    // qué hizo en cada fase esta semana
  createdAt   DateTime @default(now())

  project AcademySaasProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, weekNumber])
  @@index([projectId])
}

// Resultado del Demo Day
model AcademyDemoDayResult {
  id                  String   @id @default(cuid())
  projectId           String   @unique
  cohortId            String
  presentedAt         DateTime
  scoreTotal          Decimal? @db.Decimal(5, 2)   // 0..100
  scoreFunctionality  Decimal? @db.Decimal(5, 2)
  scoreArchitecture   Decimal? @db.Decimal(5, 2)
  scoreCode           Decimal? @db.Decimal(5, 2)
  scoreRealUsers      Decimal? @db.Decimal(5, 2)
  scoreAICriteria     Decimal? @db.Decimal(5, 2)
  passed              Boolean  @default(false)
  instructorNotes     String?  @db.Text
  nintyDayPlan        String?  @db.Text             // Compromiso 90 días
  linkedinPostUrl     String?
  tenantId            String
  createdAt           DateTime @default(now())

  project AcademySaasProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cohort  AcademyCohort      @relation(fields: [cohortId], references: [id])
  tenant  Tenant             @relation(fields: [tenantId], references: [id])

  @@index([cohortId])
  @@index([tenantId])
}

// ============================================================
// SECCIÓN 4: GAMIFICACIÓN Y ENGAGEMENT
// ============================================================

model AcademyBadge {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  description String
  icon        String                              // emoji o nombre de ícono
  condition   BadgeCondition
  threshold   Int?                               // ej: 5 para "5 lecciones completadas"
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  earned      AcademyBadgeEarned[]

  @@unique([name, tenantId])
  @@index([tenantId])
  @@index([condition])
}

model AcademyBadgeEarned {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge AcademyBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
}

// Anuncio/Notificación para la cohorte
model AcademyAnnouncement {
  id         String   @id @default(cuid())
  cohortId   String?                             // null = todos los cursos del tenant
  courseId   String?
  title      String
  content    String   @db.Text
  isPinned   Boolean  @default(false)
  authorId   String
  tenantId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  cohort  AcademyCohort? @relation(fields: [cohortId], references: [id])
  course  AcademyCourse? @relation(fields: [courseId], references: [id])
  author  User           @relation(fields: [authorId], references: [id])
  tenant  Tenant         @relation(fields: [tenantId], references: [id])

  @@index([cohortId])
  @@index([tenantId])
  @@index([isPinned])
}

// ============================================================
// ENUMS ESPECÍFICOS DE KALEDACADEMY
// ============================================================

enum SessionType {
  TEORIA
  PRACTICA
  LIVE
  ENTREGABLE
}

enum DayOfWeek {
  LUNES
  MIERCOLES
  VIERNES
}

enum CRALPhase {
  CONSTRUIR
  ROMPER
  AUDITAR
  LANZAR
}

enum KaledSessionType {
  LESSON_SUPPORT    // Ayuda en sesión específica
  CODE_REVIEW       // Revisión de código del estudiante
  DELIVERABLE_HELP  // Ayuda con entregable
  GENERAL_QUESTION  // Pregunta general del bootcamp
  PROJECT_REVIEW    // Revisión del SaaS del estudiante
}

enum DeliverableStatus {
  PENDIENTE
  ENTREGADO
  EN_REVISION
  APROBADO
  RECHAZADO
}

enum SaasProjectStatus {
  EN_CONSTRUCCION
  EN_STAGING
  EN_PRODUCCION
  LANZADO        // URL propia + usuarios reales
}

enum BadgeCondition {
  LESSONS_COMPLETED
  DELIVERABLES_APPROVED
  STREAK_DAYS
  QUIZ_PERFECT_SCORE
  FIRST_DEPLOY
  REAL_USERS_3
  DEMO_DAY_PASSED
  ALL_CRAL_DONE
}
