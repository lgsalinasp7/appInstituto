// Agrega al final del schema.prisma existente

model KaledCodeReview {
  id             String    @id @default(cuid())
  tenantId       String
  userId         String
  lessonId       String?
  cralPhase      String
  codeSubmitted  String    @db.Text
  feedback       String    @db.Text
  errorPatterns  String[]
  weekNumber     Int?
  sessionNumber  Int?
  status         String    @default("PENDING_APPROVAL")
  approvedBy     String?
  approvedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([userId])
  @@index([tenantId])
  @@index([status])
  @@map("kaled_code_reviews")
}

model KaledStudentErrorPattern {
  id           String    @id @default(cuid())
  tenantId     String
  userId       String
  errorPattern String
  errorLabel   String
  occurrences  Int       @default(1)
  firstSeenAt  DateTime  @default(now())
  lastSeenAt   DateTime  @updatedAt
  lessonIds    String[]
  resolved     Boolean   @default(false)
  resolvedAt   DateTime?

  @@index([userId, tenantId])
  @@map("kaled_student_error_patterns")
}

model KaledInstructorTask {
  id           String    @id @default(cuid())
  tenantId     String
  instructorId String
  studentId    String
  type         String
  priority     String    @default("MEDIUM")
  title        String
  diagnosis    String    @db.Text
  suggestion   String    @db.Text
  metadata     Json?
  status       String    @default("PENDING")
  reviewedAt   DateTime?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([instructorId, status])
  @@index([tenantId])
  @@map("kaled_instructor_tasks")
}

model KaledDeliverableEvaluation {
  id                  String    @id @default(cuid())
  tenantId            String
  submissionId        String
  userId              String
  cralPhase           String
  codeReviewed        String?   @db.Text
  feedbackConstruir   String?   @db.Text
  feedbackRomper      String?   @db.Text
  feedbackAuditar     String?   @db.Text
  feedbackLanzar      String?   @db.Text
  overallFeedback     String    @db.Text
  strengths           String[]
  improvements        String[]
  socraticQuestions   String[]
  status              String    @default("PENDING_APPROVAL")
  approvedBy          String?
  approvedAt          DateTime?
  visibleToStudent    Boolean   @default(false)
  createdAt           DateTime  @default(now())

  @@index([submissionId])
  @@index([status])
  @@map("kaled_deliverable_evaluations")
}

model KaledCohortMetrics {
  id                  String   @id @default(cuid())
  tenantId            String
  cohortId            String
  snapshotDate        DateTime @db.Date
  totalStudents       Int      @default(0)
  studentsOnTrack     Int      @default(0)
  studentsAtRisk      Int      @default(0)
  saasDeployedCount   Int      @default(0)
  avgProgress         Decimal? @db.Decimal(5,2)
  totalKaledQueries   Int      @default(0)
  cacheHitRate        Decimal? @db.Decimal(5,2)
  tokensSaved         Int      @default(0)
  deliverablesApproved Int     @default(0)

  @@unique([cohortId, snapshotDate])
  @@map("kaled_cohort_metrics")
}
```

